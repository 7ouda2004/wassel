# Wasel Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/wasel_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# WhatsApp API (optional)
WHATSAPP_API_KEY=
WHATSAPP_PHONE=201119056895

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080
